# scripts/.env.example — copy to scripts/.env and fill in.
# scripts/.env is gitignored. NEVER commit real secrets.
#
# NOTE (reuse from the suite): most of these values are PeerLoom-account-wide and
# are IDENTICAL to pearlist/pearguard scripts/.env. Copy one of those as a
# starting point and only change the two APP-SPECIFIC blocks called out below
# (Android upload keystore + ASC_APP_ID).

# ==========================================================================
# APP-SPECIFIC — must be unique to PearPetal
# ==========================================================================

# --- Android upload keystore ------------------------------------------------
# PearPetal signs with the `pearpetal` alias in the SHARED keystore
# (~/keystore.jks) — the same key whose SHA-256 is published in the website's
# .well-known/assetlinks.json (com.pearpetal, 34:DA:6E:42:...). Signing the
# release with any other key breaks Android App Links tap-to-open. Back up
# ~/keystore.jks offline — losing it blocks all future Play updates.
KEYSTORE_FILE=$HOME/keystore.jks
KEYSTORE_PASSWORD=
KEY_ALIAS=pearpetal
KEY_PASSWORD=

# --- App Store numeric app ID (PearPetal's own record) ----------------------
# The com.pearpetal App Store Connect record exists (created 2026-07-10).
# Find the numeric id with: asc apps list
ASC_APP_ID=

# ==========================================================================
# SHARED — same values as pearlist/pearguard scripts/.env (account-wide)
# ==========================================================================

# --- Zapstore / Nostr signing identity (shared PeerLoom nsec) ---------------
SIGN_WITH=

# --- GitHub (shared; falls back to `gh auth token` if unset) ----------------
GITHUB_TOKEN=
# GITHUB_REMOTE=origin

# --- App Store Connect API key (shared PeerLoom-CI key) ---------------------
# Same key ID / issuer / .p8 / team as the sibling apps.
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_PRIVATE_KEY_PATH=$HOME/.appstoreconnect/AuthKey_<KEY_ID>.p8
ASC_TEAM_ID=G79ALD29NA

# --- Google Play (shared service account or gcloud ADC) ---------------------
# PLAY_SERVICE_ACCOUNT_JSON=$HOME/.config/peerloom/play-service-account.json
# ...or gcloud application-default creds + a quota project:
# PLAY_QUOTA_PROJECT=
PLAY_TRACK=internal

# --- Build hosts (shared) ---------------------------------------------------
# MAC_MINI_HOST=Tims-Mac-mini.local
