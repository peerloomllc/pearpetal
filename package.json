{
  "name": "pearpetal",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "description": "Private P2P menstrual / fertility cycle tracker. Part of the PeerLoom suite, built on @peerloom/core.",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "build:bare": "bare-pack --linked --defer fs --defer path src/bare.js -o assets/bare-universal.bundle",
    "build:bare:ios": "bare-pack --preset ios --defer fs --defer path src/bare.js -o assets/bare-ios.bundle",
    "build:ui": "node scripts/build-ui.mjs",
    "test": "node --test test/*.test.js",
    "verify": "node --test test/*.test.js && npm run build:bare && npm run build:bare:ios && npm run build:ui"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@peerloom/core": "file:../peerloom-core",
    "@react-native-async-storage/async-storage": "2.2.0",
    "autobase": "^7.25.1",
    "b4a": "^1.8.0",
    "babel-preset-expo": "~54.0.10",
    "compact-encoding": "^2.19.2",
    "corestore": "^7.8.0",
    "expo": "^54.0.10",
    "expo-asset": "~12.0.9",
    "expo-build-properties": "^1.0.9",
    "expo-constants": "^18.0.9",
    "expo-file-system": "~19.0.21",
    "expo-haptics": "~15.0.8",
    "expo-linking": "^8.0.8",
    "expo-router": "^6.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-system-ui": "^6.0.7",
    "hyperbee": "^2.27.3",
    "hyperblobs": "^2.12.1",
    "hyperdht": "^6.29.0",
    "hyperswarm": "^4.17.0",
    "protomux": "^3.10.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-b4a": "^0.0.4",
    "react-native-bare-kit": "^0.12.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-webview": "13.15.0",
    "sodium-universal": "^5.0.1"
  },
  "devDependencies": {
    "@hyperswarm/testnet": "^3.1.4",
    "@types/react": "^19.1.3",
    "bare": "^1.28.5",
    "bare-bundle": "^1.10.0",
    "bare-pack": "^2.0.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.3"
  }
}
