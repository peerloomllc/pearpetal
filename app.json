{
  "expo": {
    "name": "PearPetal",
    "slug": "pearpetal",
    "version": "0.1.0",
    "newArchEnabled": true,
    "orientation": "portrait",
    "scheme": "pear",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.pearpetal",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan an invite QR code to link a device or view a partner's cycle.",
        "NSLocalNetworkUsageDescription": "PearPetal connects directly to your own devices and your partner on your Wi-Fi to sync cycle data peer-to-peer.",
        "NSBonjourServices": [
          "_hyperswarm._udp",
          "_pearpetallan._tcp"
        ]
      }
    },
    "android": {
      "package": "com.pearpetal",
      "versionCode": 100000,
      "permissions": [
        "CAMERA"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "pear",
              "host": "pearpetal",
              "pathPrefix": "/link"
            },
            {
              "scheme": "pear",
              "host": "pearpetal",
              "pathPrefix": "/join"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "peerloomllc.com",
              "pathPrefix": "/petal/link"
            },
            {
              "scheme": "https",
              "host": "peerloomllc.com",
              "pathPrefix": "/petal/join"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      [
        "expo-router"
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 29
          }
        }
      ]
    ],
    "assets": [
      "./assets/bare-universal.bundle",
      "./assets/bare-ios.bundle"
    ]
  }
}
