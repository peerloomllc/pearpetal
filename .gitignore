node_modules/
.DS_Store
*.log
dist/
build/
.expo/
# Anchored to root: the generated native projects only. Must NOT match
# modules/local-network/ios/ (the iOS source of our Expo local module).
/android/
/ios/
# Generated bundles (produced by build:bare / build:ui)
assets/*.bundle
assets/index.html
# Local P2P storage / identity - never commit
*.cores/
store/
corestore/

# Release secrets (never commit)
scripts/.env

# Zapstore publish manifest (lives locally; patched at release time)
zapstore.yaml

# Build outputs (release artifacts)
*.apk
*.aab
*.apk.sha256
*.aab.sha256
